# Copy this file to .env and fill in your provider settings.
# .env is ignored by git.

SPECTRAIL_LLM_API_KEY=
SPECTRAIL_LLM_MODEL=

# Optional. Defaults to OpenAI's chat completions endpoint.
SPECTRAIL_LLM_BASE_URL=https://api.openai.com/v1/chat/completions

# Optional. Defaults to 60 seconds.
SPECTRAIL_LLM_TIMEOUT_SECONDS=60
