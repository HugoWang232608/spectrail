      "expected_evidence_fingerprint": "b2793917b65cd81781a3bce68f010bbc8178fb02263615acbbd5d568d6e8ce97",
      "observations": [
        {
          "observation_id": "create-document-source",
          "kind": "text_source",
          "quote": "[DEMO-SRS-53] The application shall allow users to create a new empty document.",
          "page": 5,
          "expected_block_type": "paragraph",
