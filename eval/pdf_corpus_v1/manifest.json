{
  "schema_version": "pdf_corpus_v1",
  "name": "SpecTrail real-world PDF corpus v1",
  "metadata": {
    "annotation_policy": "selected source observations plus exhaustive page-level heading sets",
    "core_target": "4-6 checked-in PDFs with a separately gated reviewed-redistribution count",
    "extended_target": "8-12 provenance-locked PDFs",
    "trust_policy": "abstention is acceptable; unsupported structure must not become trusted Evidence"
  },
  "thresholds": {
    "case_pass_rate_min": 1.0,
    "case_evaluated_count_min": 5,
    "producer_family_count_min": 4,
    "external_document_case_count_min": 2,
    "redistribution_reviewed_case_count_min": 4,
    "gate_observation_pass_rate_min": 1.0,
    "gate_observation_evaluated_count_min": 20,
    "text_source_accuracy_min": 1.0,
    "text_source_evaluated_count_min": 10,
    "page_region_availability_rate_min": 1.0,
    "page_region_evaluated_count_min": 10,
    "selected_table_topology_precision_min": 1.0,
    "selected_table_topology_recall_min": 1.0,
    "table_topology_evaluated_count_min": 7,
    "continuation_pair_accuracy_min": 1.0,
    "continuation_pair_evaluated_count_min": 3,
    "continuation_false_positive_count_max": 0
  },
  "cases": [
    {
      "case_id": "ieee29148_word_export",
      "document": "../../tests/fixtures/ieee29148_srs_example.pdf",
      "tier": "core",
      "source": {
        "provenance": "external_document",
        "producer_family": "Microsoft Word for Office 365",
        "source_url": "https://www.cin.ufpe.br/~in1020/docs/publicacoes/IEEE29148-srs_example.pdf",
        "redistribution_status": "existing_checked_fixture_terms_unverified",
        "license_note": "Existing repository fixture; provenance is recorded, but redistribution terms have not yet been independently classified.",
        "source_sha256": "db505b45a4771b5b4a444a6a88f48e19167fb4d0ba84058c18b6a9875aff83b0",
        "expected_pdf_metadata": {
          "creator": "Microsoft® Word for Office 365",
          "producer": "Microsoft® Word for Office 365",
          "title": "Example Software Requirements Specification Document for ReqView"
        }
      },
      "expected_parser_name": "pdf_parser_v2",
