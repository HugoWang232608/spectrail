            "2. Requirements",
            "2.2.1 File Operations",
            "2.2.1.1 Create Document"
          ]
        },
        {
          "observation_id": "open-document-source",
          "kind": "text_source",
          "quote": "[DEMO-SRS-56] The application shall allow users to open a document from a chosen file.",
          "page": 5,
          "expected_block_type": "paragraph",
          "expected_section_path": [
            "2. Requirements",
            "2.2.1 File Operations",
            "2.2.1.2 Open File"
          ]
        },
        {
          "observation_id": "table-of-contents-source",
          "kind": "text_source",
          "quote": "[DEMO-SRS-80] The application shall display the table of contents containing section headings organized according to their document tree hierarchy.",
          "page": 6,
          "expected_block_type": "paragraph",
          "expected_section_path": [
            "2. Requirements",
            "2.2.2 Document View",
            "2.2.2.1 Table of Contents"
          ]
        },
        {
          "observation_id": "smooth-scrolling-source",
          "kind": "text_source",
          "quote": "[DEMO-SRS-173] While a user scrolls the requirements table, the application should not display scrolling jerks longer than 200ms.",
          "page": 10,
          "expected_block_type": "paragraph",
          "expected_section_path": [
            "2. Requirements",
            "2.4.3 Smooth Scrolling"
          ]
        },
        {
          "observation_id": "internet-isolation-source",
          "kind": "text_source",
          "quote": "[DEMO-SRS-176] The application shall not send any project data to the Internet.",
          "page": 10,
          "expected_block_type": "paragraph",
          "expected_section_path": [
            "2. Requirements",
            "2.5 Logical database requirements"
          ]
        },
        {
          "observation_id": "page-5-heading-set",
          "kind": "heading_page",
          "gate": false,
          "page": 5,
          "expected_headings": [
            "2. Requirements",
            "2.2.1 File Operations",
            "2.2.1.1 Create Document",
            "2.2.1.2 Open File",
            "2.2.1.3 Save Local File",
            "2.2.1.4 Document Template",
            "2.2.1.5 Import",
            "2.2.1.6 Export",
            "2.2.2 Document View"
          ],
          "notes": "Report-only until the real-world heading baseline is large enough to set stable thresholds."
        },
        {
          "observation_id": "page-1-decoration-vs-heading",
          "kind": "heading_page",
          "gate": false,
          "page": 1,
          "expected_headings": [],
          "notes": "The date currently exposes a known heading false positive and intentionally remains report-only."
        }
      ]
    },
